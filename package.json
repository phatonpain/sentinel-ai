{
  "name": "sentinel-ai",
  "private": true,
  "version": "0.1.0",
  "description": "Sentinel AI — AI-Native Application Security Platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:migrate:dev": "pnpm --filter api-proxy db:migrate:dev",
    "db:generate": "pnpm --filter api-proxy db:generate",
    "db:studio": "pnpm --filter api-proxy db:studio",
    "docker:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "@prisma/client", "@prisma/engines", "esbuild", "msgpackr-extract", "prisma"]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
