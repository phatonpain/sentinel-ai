{
  "name": "api-proxy",
  "version": "0.1.0",
  "description": "Sentinel AI API Proxy — NestJS core engine",
  "scripts": {
    "build": "nest build",
    "build:verify": "npm run build && node -e \"const fs=require('fs');const p='dist/modules/inspector/dto/inspect-request.dto.js';if(!fs.existsSync(p)){console.error('MISSING: '+p);process.exit(1)}console.log('OK: '+p);\"",
    "postbuild": "node -e \"const fs=require('fs');const p='dist/modules/inspector/dto/inspect-request.dto.js';if(!fs.existsSync(p)){console.error('CRITICAL: DTO files missing from dist. Aborting.');process.exit(1)}\"",
    "dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.12.0",
    "@sentinel/shared-types": "workspace:*",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "jose": "^5.2.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "stripe": "^22.1.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@sentinel/eslint-config": "workspace:*",
    "@sentinel/tsconfig": "workspace:*",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "prisma": "^5.12.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
